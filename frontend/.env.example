# Copy to .env.local and fill in values. Restart dev server after changes.

MONGODB_URI=mongodb://localhost:27017/testimonial-saas
JWT_SECRET=use-a-long-random-string-in-production

# App URL (used after Lemon Squeezy checkout redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Lemon Squeezy — from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=

# Webhook signing secret (must match the secret you set on the webhook in Lemon Squeezy)
LEMONSQUEEZY_WEBHOOK_SECRET=

# Variant IDs: in Lemon Squeezy, Products → your subscription product → each price/variant has an ID in the URL or API
LEMONSQUEEZY_VARIANT_MONTHLY=
LEMONSQUEEZY_VARIANT_SIX_MONTH=
# Optional legacy name (used if SIX_MONTH is empty):
# LEMONSQUEEZY_VARIANT_QUARTERLY=
LEMONSQUEEZY_VARIANT_YEARLY=

# Optional
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional — Ahrefs Web Analytics (omit to disable the script)
# NEXT_PUBLIC_AHREFS_WEB_ANALYTICS_KEY=
